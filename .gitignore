# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

.idea

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (echte Secrets ignorieren, Vorlage aber einchecken)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# BandMate-Daten (SQLite + Uploads)
/data/

# Backups — liegen produktiv außerhalb des Repos, im Dev-Default (DATA_DIR=./data)
# aber daneben. Auf keinen Fall einchecken.
/bandmate-backups/
