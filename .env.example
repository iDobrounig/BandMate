# Production Requirement: Session cookies must have a secret key that is at least 32 characters long
# For example, generate using: openssl rand -base64 32
SESSION_SECRET=

# Public URL of the app (for links in emails), without a trailing slash
APP_URL=https://band.example.com

# Data directory (SQLite + Uploads). Default: ./data
# In production, put this OUTSIDE the clone so "git pull" never touches it.
# DATA_DIR=/var/bandmate-data

# --- Backup & Papierkorb (trash) -------------------------------------------
# Read by the app AND by ./scripts/backup.sh and "npm run trash:purge",
# so DATA_DIR only has to be set once, right here.
#
# Where backups go. Default: <DATA_DIR>/../bandmate-backups
# Put this on a DIFFERENT disk than DATA_DIR — otherwise one disk failure
# takes both with it.
# BACKUP_DIR=/mnt/backup/bandmate
#
# How long backups are kept, in days. Default: 35
# Must stay LONGER than the 30-day trash retention (TRASH_RETENTION_DAYS in
# lib/constants.ts): otherwise a permanently deleted file is in no backup
# either, because the runs from its lifetime have already rotated out.
# RETENTION_DAYS=35
#
# This many backup runs are always kept, no matter how old. Default: 3
# KEEP_MIN=3

# SMTP for email notifications (optional — without these values, no emails will be sent)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=band@example.com
# SMTP_PASS=
# SMTP_FROM="BandMate <band@example.com>"

# Only for “npm run seed” (first admin user)
# ADMIN_NAME=Ingo
# ADMIN_EMAIL=ingo@example.com
# ADMIN_PASSWORD=
