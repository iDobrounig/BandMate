# Pflicht in Produktion: mind. 32 Zeichen langes Geheimnis für Session-Cookies
# z.B. generieren mit: openssl rand -base64 32
SESSION_SECRET=

# Öffentliche URL der App (für Links in E-Mails), ohne Slash am Ende
APP_URL=https://band.example.com

# Datenverzeichnis (SQLite + Uploads). Standard: ./data
# DATA_DIR=/pfad/zu/daten

# SMTP für E-Mail-Benachrichtigungen (optional — ohne diese Werte werden keine Mails verschickt)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=band@example.com
# SMTP_PASS=
# SMTP_FROM="Bandraum <band@example.com>"

# Nur für "npm run seed" (erster Admin-User)
# ADMIN_NAME=Ingo
# ADMIN_EMAIL=ingo@example.com
# ADMIN_PASSWORD=
